    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Use esta ferramenta APENAS para apagar, deletar ou remover um lançamento financeiro. Você deve extrair da fala do usuário o parâmetro 'valor' (apenas números, convertendo vírgula para ponto) que ele deseja apagar.",
        "operation": "executeQuery",
        "query": "DELETE FROM lancamentos \nWHERE usuario = '{{ $json.body.usuario }}' \nAND valor = {{ $json.Query_Parameters.replace(/[^0-9.]/g, '') }};",
        "options": {
          "queryReplacement": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Query_Parameters', ``, 'string') }}"
        }
      },
