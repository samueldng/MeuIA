    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Use APENAS para alterar, editar ou atualizar um lançamento financeiro. Você precisa fornecer dois parâmetros: 'nome_categoria' (a palavra-chave, ex: consultoria) e 'novo_valor' (apenas números).",
        "operation": "executeQuery",
        "query": "UPDATE lancamentos \nSET valor = {{ $json.Query_Parameters.match(/novo_valor=([0-9.]+)/)[1] }}\nWHERE usuario = '{{ $json.body.usuario }}' \nAND categoria ILIKE '%' || '{{ decodeURIComponent($json.Query_Parameters.match(/nome_categoria=([^&]+)/)[1]) }}' || '%';",
        "options": {
          "queryReplacement": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Query_Parameters', ``, 'string') }}"
        }
      },
