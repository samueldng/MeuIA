# ─── Server ─────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ─── PostgreSQL ─────────────────────────────
# For PgBouncer: append ?pgbouncer=true&connection_limit=5
DATABASE_URL=postgresql://user:password@localhost:5432/meuia

# ─── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Supabase (JWT Validation Only) ─────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Groq (LLM) ────────────────────────────
GROQ_API_KEY=gsk_your_api_key

# ─── BullMQ ─────────────────────────────────
BULL_QUEUE_PREFIX=meuia

# ─── Payments (Fase 2) ─────────────────────
# MERCADOPAGO_ACCESS_TOKEN=
# STRIPE_SECRET_KEY=
