    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Use esta ferramenta SEMPRE que o usuário pedir um resumo financeiro, extrato, histórico de lançamentos, saldo atual ou total de gastos e ganhos.",
        "operation": "executeQuery",
        "query": "SELECT tipo, valor, categoria, descricao, to_char(data, 'DD/MM/YYYY') as data \nFROM lancamentos \nWHERE usuario = '{{ $json.body.usuario }}' \nORDER BY data DESC \nLIMIT 50;",
